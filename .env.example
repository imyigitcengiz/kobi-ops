# =============================================================================
# KobiOps — Ortam Değişkenleri Referans Şablonu
# =============================================================================
#
# TAK-ÇALIŞTIR (Coolify / Dokploy / 1Panel):
#   Bu dosyayı yazmadan deploy edebilirsiniz.
#   docker-compose.yaml + bootstrap-env.sh üretim değerlerini otomatik verir.
#   Panel Environment sekmesine yapıştırmanız ZORUNLU DEĞİL.
#
# Bu şablon yalnızca:
#   - manuel override istediğinizde
#   - hangi değişkenin ne işe yaradığını görmek için
#
# Kopyalamak için: cp .env.example .env  (isteğe bağlı)
#
# =============================================================================

# -----------------------------------------------------------------------------
# A) OTOMATİK — boş bırakın (bootstrap-env.sh + panel domain doldurur)
# -----------------------------------------------------------------------------
# DJANGO_SECRET_KEY=              → /data/.django_secret_key (kalıcı, otomatik üretilir)
# DJANGO_ALLOWED_HOSTS=           → Coolify SERVICE_FQDN_APP / domain
# DJANGO_CSRF_TRUSTED_ORIGINS=    → Coolify SERVICE_URL_APP / https URL
# DJANGO_SECURE_SSL=              → HTTPS domain=1, sslip.io=0 (otomatik)

# Coolify domain tanımlayınca gelir (elle yazmayın):
# SERVICE_FQDN_APP=
# SERVICE_URL_APP=

# -----------------------------------------------------------------------------
# B) COMPOSE İÇİNDE HAZIR — docker-compose.yaml'de zaten tanımlı
# -----------------------------------------------------------------------------
# PORT=8000
# DATA_DIR=/data
# DJANGO_DB_PATH=/data/db.sqlite3
# DJANGO_MEDIA_ROOT=/data/media
# DJANGO_SERVE_MEDIA=1
# WHATSAPP_BRIDGE_URL=http://whatsapp_bridge:3939
# DJANGO_WHATSAPP_BRIDGE_CAN_SPAWN=0
# DJANGO_WHATSAPP_BRIDGE_AUTO_START=0
# DJANGO_WHATSAPP_BRIDGE_WAIT_ON_START=1
# GY_REQUIRE_PERSISTENT_VOLUME=1
# GY_ALLOW_EPHEMERAL_DATA=0
# KOBIOPS_COMPOSE_STACK=1
# MEDIA_COMPRESS_ENABLED=1

# -----------------------------------------------------------------------------
# C) İSTEĞE BAĞLI OVERRIDE — sadece değiştirmek istediğinizde açın
# -----------------------------------------------------------------------------

# İlk kurulum: admin / admin — girişten sonra 0 yapın + redeploy
DJANGO_ENSURE_SUPERADMIN=1

# Üretimde 0 bırakın
DJANGO_DEBUG=0

# sslip.io test domainleri otomatik izinli (kapatmak için 0)
# DJANGO_ALLOW_SSLIP_HOSTS=1

# WhatsApp köprüsü bekleme süresi (saniye)
# DJANGO_WHATSAPP_BRIDGE_WAIT_TIMEOUT=30

# Medya sıkıştırma
# MEDIA_COMPRESS_ENABLED=1
# MEDIA_IMAGE_MAX_SIDE=1920
# MEDIA_IMAGE_MAX_QUALITY=85
# MEDIA_IMAGE_FORMAT=JPEG
# MEDIA_FFMPEG_PATH=ffmpeg
# MEDIA_FFMPEG_TIMEOUT=300

# Yükleme limitleri
# DJANGO_UPLOAD_MAX_MEMORY=54525952
# DJANGO_UPLOAD_MAX_FILES=20

# Yedek yükleme üst sınırı (bayt)
# GY_BACKUP_MAX_UPLOAD_BYTES=524288000

# Kalıcı disk — compose named volume yeterli; test dışında dokunmayın
# GY_REQUIRE_PERSISTENT_VOLUME=1
# GY_ALLOW_EPHEMERAL_DATA=0

# -----------------------------------------------------------------------------
# D) YEREL GELİŞTİRME — Docker dışında runserver için
# -----------------------------------------------------------------------------
# DJANGO_DEBUG=1
# WHATSAPP_BRIDGE_URL=http://127.0.0.1:3939
# DJANGO_WHATSAPP_BRIDGE_CAN_SPAWN=1
# DJANGO_WHATSAPP_BRIDGE_AUTO_START=1
# WHATSAPP_BRIDGE_NODE=C:\Program Files\nodejs\node.exe
