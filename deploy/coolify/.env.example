# Coolify → Environment Variables (örnek)

DJANGO_DEBUG=0
DJANGO_SECRET_KEY=uzun-rastgele-anahtar
DJANGO_ALLOWED_HOSTS=panel.ornek.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://panel.ornek.com
DJANGO_SECURE_SSL=1

# Kalıcı volume /data mount edildiğinde (önerilen)
DATA_DIR=/data
DJANGO_DB_PATH=/data/db.sqlite3
DJANGO_MEDIA_ROOT=/data/media

# Coolify genelde PORT verir; elle 8000 de olur
PORT=8000
DAPHNE_HOST=0.0.0.0

DJANGO_WHATSAPP_BRIDGE_AUTO_START=0
WHATSAPP_BRIDGE_URL=http://127.0.0.1:3939

# Medya sıkıştırma (sunucuda; resim Pillow, video/ses ffmpeg)
MEDIA_COMPRESS_ENABLED=1
MEDIA_IMAGE_MAX_SIDE=1920
MEDIA_IMAGE_MAX_QUALITY=85
# MEDIA_IMAGE_FORMAT=JPEG
# MEDIA_FFMPEG_PATH=ffmpeg

# İlk deploy: admin/admin oluştur (sonra şifreyi değiştirin)
# DJANGO_ENSURE_SUPERADMIN=1
