# Bu dosyayı proje kökünde .env.docker olarak kopyalayın:
#   copy deploy\docker\.env.example .env.docker

# --- Zorunlu (üretim) ---
DJANGO_DEBUG=0
DJANGO_SECRET_KEY=buraya-uzun-rastgele-bir-anahtar-yazin
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,sunucu-ip-veya-domain
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000

# HTTPS reverse proxy (Nginx/Traefik) arkasında ise açın:
# DJANGO_SECURE_SSL=1
# DJANGO_CSRF_TRUSTED_ORIGINS=https://panel.sizin.com
# DJANGO_ALLOWED_HOSTS=panel.sizin.com

# --- Kalıcı veri (volume /data) ---
DATA_DIR=/data
DJANGO_DB_PATH=/data/db.sqlite3
DJANGO_MEDIA_ROOT=/data/media
DJANGO_SERVE_MEDIA=1

# --- Sunucu ---
PORT=8000
DAPHNE_HOST=0.0.0.0

# --- İlk kurulum: admin / admin (sonra şifreyi değiştirin) ---
DJANGO_ENSURE_SUPERADMIN=1

# --- Yükleme limitleri ---
DJANGO_UPLOAD_MAX_MEMORY=52428800
DJANGO_UPLOAD_MAX_FILES=20

# --- Medya sıkıştırma ---
MEDIA_COMPRESS_ENABLED=1
MEDIA_IMAGE_MAX_SIDE=1920
MEDIA_IMAGE_MAX_QUALITY=85

# --- WhatsApp (köprü ayrı çalışıyorsa) ---
DJANGO_WHATSAPP_BRIDGE_AUTO_START=0
WHATSAPP_BRIDGE_URL=http://host.docker.internal:3939
